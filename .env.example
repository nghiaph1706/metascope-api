# ── Riot API ─────────────────────────────────────────────────────
# Lấy tại: https://developer.riotgames.com
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Regional URL — dùng cho Account v1, TFT Match v1
# VN2/KR/JP1/TW2 → asia | NA1/BR1/LA1/LA2 → americas | EUW1/EUN1/TR1/RU → europe
RIOT_REGIONAL_URL=https://asia.api.riotgames.com

# Platform URL — dùng cho TFT Summoner v1, TFT League v1
# Dùng platform ID của server: vn2, kr, na1, euw1, ...
RIOT_PLATFORM_URL=https://vn2.api.riotgames.com

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://metascope:metascope@localhost:5432/metascope
SYNC_DATABASE_URL=postgresql://metascope:metascope@localhost:5432/metascope

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_CONCURRENCY=2

# ── App Config ───────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-secret-key-in-production
# Comma-separated list. Dùng * cho dev, set domain cụ thể cho prod
ALLOWED_ORIGINS=*

# ── Auth (JWT) ──────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── OAuth (optional, để trống nếu không dùng) ──────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8000

# ── Payments (optional, để trống nếu chưa dùng) ────────────────
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Rate Limiting (Riot API) ─────────────────────────────────────
RATE_LIMIT_PER_SECOND=20
RATE_LIMIT_PER_2MIN=100
RATE_LIMIT_MAX_CONCURRENT=20
RATE_LIMIT_RETRY_MAX=3

# ── Cache TTL (giây) ─────────────────────────────────────────────
CACHE_TTL_TIER_LIST=900         # 15 phút
CACHE_TTL_COMP_LIST=900         # 15 phút
CACHE_TTL_COMP_DETAIL=3600      # 1 giờ
CACHE_TTL_CHAMPION_STATS=3600   # 1 giờ
CACHE_TTL_TRAIT_STATS=3600      # 1 giờ
CACHE_TTL_PLAYER=1800           # 30 phút
CACHE_TTL_SEARCH=300            # 5 phút
CACHE_TTL_LEADERBOARD=1800      # 30 phút
CACHE_TTL_PATCHES=21600         # 6 giờ
CACHE_TTL_STATIC_DATA=21600     # 6 giờ
CACHE_TTL_GUIDES=300            # 5 phút
CACHE_TTL_MATCH_ANALYSIS=86400  # 24 giờ
CACHE_TTL_ANALYSIS_SUMMARY=1800 # 30 phút

# ── Pagination ───────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ── Stats Calculation ────────────────────────────────────────────
MIN_SAMPLE_SIZE=100     # Số game tối thiểu để tính stats
PATCH_DECAY_FACTOR=0.85
# Tier boundaries: percentile >= giá trị → tier đó
TIER_BOUNDARIES=S:90,A:70,B:45,C:20,D:0

# ── TFT Config ───────────────────────────────────────────────────
TFT_SET_NUMBER=13
DEFAULT_REGION=vn2
# Comma-separated: regions to collect data from. Thêm region = thêm API calls
COLLECT_REGIONS=vn2

# ── Flower (Celery Monitor) ─────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=admin
